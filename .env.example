# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Connect to Supabase via connection pooling with Supavisor.
DATABASE_URL="postgresql://localhost:5432/expo-starter"
# Direct connection to the database. Used for migrations.
DATABASE_DIRECT_URL="postgresql://localhost:5432/expo-starter"

# Web
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# Auth
BETTER_AUTH_SECRET=thisisaverylongandsecuresecretstring
RESEND_API_KEY=re_123

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Stripe
# Get these from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Create products/prices in Stripe Dashboard and paste the price IDs here
# STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# RevenueCat (for mobile in-app purchases)
# Generate a webhook auth token and set it here + in RevenueCat Dashboard webhook config
# REVENUECAT_WEBHOOK_SECRET=

# Sentry
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# PostHog
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Path to Google google-service-account-file.json
# GOOGLE_APPLICATION_CREDENTIALS=

# For use in prod instead of GOOGLE_APPLICATION_CREDENTIALS (See https://stackoverflow.com/a/77284609/5408068)
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_PRIVATE_KEY=
# GOOGLE_CLOUD_CLIENT_EMAIL=
