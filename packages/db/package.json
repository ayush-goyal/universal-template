{
  "name": "@acme/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "generate": "prisma generate",
    "clean": "git clean -xdf .cache .turbo dist node_modules generated",
    "format": "prettier --write . --ignore-path ../../.gitignore",
    "lint": "eslint --fix .",
    "db:migrate": "pnpm with-env prisma migrate dev",
    "db:migrate:prod": "pnpm with-env prisma migrate deploy",
    "db:studio": "pnpm with-env prisma studio",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "dotenv -e ../../.env --",
    "postinstall": "pnpm with-env prisma generate && pnpm with-env prisma format"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "minimatch": "^10.1.1",
    "pg": "^8.16.3",
    "prisma": "^7.7.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@acme/vitest-config": "workspace:^",
    "@types/pg": "^8.16.0",
    "dotenv-cli": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "^3.2.1"
  },
  "prettier": "@acme/prettier-config",
  "lint-staged": {
    "*.{js,ts,tsx}": "eslint --fix",
    "*.{js,ts,tsx,json,yml,yaml,css,html,md}": "prettier --write"
  }
}
