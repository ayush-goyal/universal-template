    "serve:web": "npx serve dist",
    "start": "expo start --dev-client",
    "submit:ios": "eas submit --profile production --platform ios --path",
    "submit:android": "eas submit --profile production --platform android --path",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "web": "expo start --web"
